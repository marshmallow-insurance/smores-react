{
	"compilerOptions": {
		"outDir": "./dist",
		"module": "esnext",
		"target": "esnext",
		"lib": [
			"esnext",
			"dom",
			"dom.iterable"
		],
		"types": [
			"react",
			"node",
			"vitest/globals",
			"./src/styled.ts"
		],
		"sourceMap": true,
		"inlineSources": true,
		"jsx": "react-jsx",
		"declaration": true,
		"moduleResolution": "Bundler",
		"paths": {
			"ActionDropdown/*": [
				"./src/ActionDropdown/*"
			],
			"Icon": [
				"./src/Icon"
			],
			"ProgressIndicator/*": [
				"./src/ProgressIndicator/*"
			],
			"RadioGroup/*": [
				"./src/RadioGroup/*"
			],
			"TextDateOfBirthInput": [
				"./src/TextDateOfBirthInput"
			],
			"utils/*": [
				"./src/utils/*"
			]
		},
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noUnusedLocals": true,
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*",
		"src/global.d.ts",
		"src/styled.ts",
		"vite.config.ts",
		"vitest.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"scripts"
	]
}
