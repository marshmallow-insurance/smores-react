{
	"compilerOptions": {
		"outDir": "./dist",
		"module": "esnext",
		"target": "esnext",
		"lib": [
			"esnext",
			"dom"
		],
		"types": [
			"react",
			"node",
			"vitest/globals",
			"./src/styled.ts"
		],
		"sourceMap": true,
		"inlineSources": true,
		"jsx": "react-jsx",
		"declaration": true,
		"moduleResolution": "Bundler",
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noUnusedLocals": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*",
		"src/global.d.ts",
		"src/styled.ts",
		"vite.config.ts",
		"vitest.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"scripts"
	]
}
