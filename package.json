{
  "name": "@mrshmllw/smores-react",
  "version": "16.0.3",
  "description": "Collection of React components used by Marshmallow Technology",
  "main": "./dist/index.js",
  "type": "module",
  "keywords": [
    "react",
    "components",
    "design system",
    "component library"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./beta": {
      "types": "./dist/beta/index.d.ts",
      "default": "./dist/beta/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc --p ./tsconfig.build.json",
    "build-storybook": "storybook build -c .storybook",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --fix",
    "prepublishOnly": "npm run build",
    "start": "npm run storybook",
    "storybook": "storybook dev -p 6006",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "npm run test-storybook --maxWorkers=2",
    "test:coverage": "vitest --coverage --silent",
    "test:watch": "vitest --watch --silent",
    "test": "vitest --silent",
    "updateSnaps": "vitest --u",
    "snyk-protect": "snyk-protect",
    "prepare": "npm run snyk-protect && husky",
    "pre-commit-lint": "npm run check-types && lint-staged",
    "commitlint": "commitlint --edit",
    "fix-package-lock-conflicts": "echo \"Make sure conflicts in package.json are resolved before running this script\" && npm i --package-lock-only"
  },
  "dependencies": {
    "@awesome.me/kit-46ca99185c": "^1.0.22",
    "@floating-ui/react": "0.27.19",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@lexical/code": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@mrshmllw/smores-foundations": "^1.1.0",
    "body-scroll-lock": "^4.0.0-beta.0",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.7",
    "fuse.js": "^7.4.0",
    "lexical": "^0.45.0",
    "polished": "^4.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@mrshmllw/campfire": "^6.1.2",
    "@snyk/protect": "^1.1305.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@storybook/test-runner": "^0.24.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "axe-playwright": "^2.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "husky": "^9.1.7",
    "jest-styled-components": "^7.4.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "storybook": "^10.2.13",
    "styled-components": "^6.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.15",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marshmallow-insurance/smores-react.git"
  },
  "author": "Todor Tsankov",
  "license": "MIT",
  "homepage": "https://github.com/marshmallow-insurance/smores-react#readme",
  "snyk": true
}
